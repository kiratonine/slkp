generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AgentSessionStatus {
  ACTIVE
  REVOKED
}

enum BridgePaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum BridgePaymentDecision {
  APPROVED
  REJECTED
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  passwordHash    String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  balance         Balance?
  agentSettings   AgentSettings?
  agentSessions   AgentSession[]

  @@map("users")
}

model Balance {
  id        String   @id @default(uuid())
  userId    String   @unique
  amountKzt Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("balances")
}

model AgentSettings {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  isEnabled               Boolean  @default(false)
  dailyLimitKzt           Int      @default(0)
  perTransactionLimitKzt  Int      @default(0)
  requireConfirmNewSeller Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_settings")
}

model AgentSession {
  id                     String             @id @default(uuid())
  userId                 String
  name                   String
  tokenHash              String
  status                 AgentSessionStatus @default(ACTIVE)
  expiresAt              DateTime
  revokedAt              DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bridgePayments         BridgePayment[]

  @@index([userId])
  @@index([status])
  @@map("agent_sessions")
}

model BridgePayment {
  id                    String                @id @default(uuid())
  agentSessionId        String
  userId                String
  idempotencyKey        String
  sellerUrl             String
  purpose               String?
  paymentRequiredB64    String
  paymentSignatureB64   String?
  amountAtomic          String?
  asset                 String?
  network               String?
  estimatedKztDebit     Int?
  decision              BridgePaymentDecision?
  rejectionReason       String?
  status                BridgePaymentStatus   @default(PENDING)
  executedAt            DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  agentSession          AgentSession          @relation(fields: [agentSessionId], references: [id], onDelete: Cascade)

  @@unique([agentSessionId, idempotencyKey])
  @@index([userId])
  @@index([status])
  @@map("bridge_payments")
}

model LedgerEntry {
  id            String   @id @default(uuid())
  userId        String
  paymentId     String
  amountKzt     Int
  type          String
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([paymentId])
  @@map("ledger_entries")
}